# Pro Photo Studio — environment variables template
# Copy to .env and fill in real values. .env is gitignored.

# ─── Core ──────────────────────────────────────────────────────────────
PPS_ENV=development              # development | staging | production
PPS_LOG_LEVEL=INFO
PPS_SECRET_KEY=changeme-min-32-chars-required-for-prod

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pps:pps@localhost:5432/pps

# ─── Redis (Celery broker + cache) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── S3-compatible storage ─────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000     # MinIO local; leave empty for AWS S3
S3_BUCKET=pps-dev
S3_ACCESS_KEY=                             # set via secret manager in prod
S3_SECRET_KEY=
S3_REGION=auto

# ─── HuggingFace (optional, for ML models) ─────────────────────────────
HF_TOKEN=                                  # https://huggingface.co/settings/tokens
HF_HOME=./.hf_cache                        # local model cache dir

# ─── Stripe (billing, optional) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Auth (Clerk or Better-Auth) ───────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ─── Webhooks (optional) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SENTRY_DSN=

# ─── Dropbox / GCS integrations (optional) ─────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
GCS_BUCKET=
GCS_SERVICE_ACCOUNT_JSON_PATH=
