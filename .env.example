# Pro Photo Studio — environment template.
# Copy to `.env` and fill in real values for local + production deployment.
# `python scripts/bootstrap_dev.py` will generate this for you in dev.

# ── Core ─────────────────────────────────────────────────────────────────────
PPS_ENV=development                 # development | staging | production
PPS_LOG_LEVEL=INFO
PPS_SECRET_KEY=                     # ≥32 chars; HMAC signing for sessions
PPS_REQUIRE_API_KEY=false           # set true in production
PPS_ALLOWED_ORIGINS=                # comma-sep prod origins; empty in dev = wildcard

# ── Domains (production only) ────────────────────────────────────────────────
PPS_DOMAIN=portal.propho.studio
API_DOMAIN=api.propho.studio
PPS_IMAGE_TAG=latest                # or a pinned vX.Y.Z

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                  # rotate before prod
DATABASE_URL=postgresql+asyncpg://pps:CHANGEME@postgres:5432/pps

# ── Redis (job broker) ───────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:CHANGEME@redis:6379/0

# ── Object storage (S3 / R2 / MinIO) ─────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000   # leave blank for AWS S3
S3_BUCKET=pps-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=auto

# ── API key for the web portal ───────────────────────────────────────────────
# Generated automatically by bootstrap_dev.py; in prod, mint via /v1/api-keys
# and set PPS_REQUIRE_API_KEY=true.
PPS_API_KEY=pps_dev_REPLACE_WITH_REAL_KEY

# ── Branding (white-label) ───────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=Pro Photo Studio
NEXT_PUBLIC_BRAND_TAGLINE=Real-estate photo enhancement, automated.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ── Integrations (optional) ──────────────────────────────────────────────────
HF_TOKEN=                           # for downloading model weights
HF_HOME=./.hf_cache
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
