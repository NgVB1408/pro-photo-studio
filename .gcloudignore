# Cloud Build context excludes — keep upload small.
# Dockerfile only COPYs: pyproject.toml uv.lock packages/core packages/data training
# Everything else can be ignored.

.git/
.github/
.pre-commit-config.yaml
*.log
runs/
node_modules/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
.venv*/
venv*/

# Not needed for training build
docs/
deploy/
examples/
investor_showcase/
scripts/
README*.md
ARCHITECTURE.md
CONTRIBUTING.md
RUNBOOK.md
SECURITY.md
LICENSE
package.json
pnpm-lock.yaml
pnpm-workspace.yaml
.env.example
.gitattributes
.gitignore

# packages/* must stay — uv.lock + root pyproject.toml reference all workspace
# members, so uv sync needs at least their pyproject.toml files present.
# Total ~7 MB; not worth slicing.

# Per-package noise
packages/**/__pycache__/
packages/**/*.pyc
packages/**/dist/
packages/**/build/
packages/**/*.egg-info/
packages/**/node_modules/
