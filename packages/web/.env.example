# Pro Photo Studio web portal — environment variables.
# Copy to .env.local for local development.

# URL of the FastAPI backend. The browser never talks to this directly —
# requests go through Next.js server actions / route handlers so the API
# key stays server-side.
PPS_API_URL=http://localhost:8000

# API key issued for this web deployment. In production, use a long-lived
# server-only key created via /v1/api-keys.
PPS_API_KEY=pps_dev_REPLACE_WITH_REAL_KEY

# Optional: bucket / CDN base for showing rendered results from object storage.
# When unset, results are streamed through the API.
PPS_PUBLIC_CDN=

# Branding / pitch knobs (swap when white-labelling).
NEXT_PUBLIC_BRAND_NAME=Pro Photo Studio
NEXT_PUBLIC_BRAND_TAGLINE=Real-estate photo enhancement, automated.
