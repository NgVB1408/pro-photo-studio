# Vertex AI custom training container for Qwen-Image-Edit LoRA fine-tune.
# Base: Vertex AI prebuilt PyTorch 2.3 + CUDA 12.1 (Python 3.10).
# Final image ~6 GB; pushes to us-central1-docker.pkg.dev/<project>/pps-training/qwen-edit.

FROM us-docker.pkg.dev/vertex-ai/training/pytorch-gpu.2-3.py310:latest

ARG UV_VERSION=0.5.7
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | sh \
    && ln -s /root/.local/bin/uv /usr/local/bin/uv

WORKDIR /opt/pps

COPY pyproject.toml uv.lock ./
# All workspace members' pyproject.toml — uv.lock is bound to the full workspace,
# so missing members make `uv sync --frozen` fail even with --package filter.
COPY packages/core/pyproject.toml packages/core/
COPY packages/data/pyproject.toml packages/data/
COPY packages/agents/pyproject.toml packages/agents/
COPY packages/ai/pyproject.toml packages/ai/
COPY packages/api/pyproject.toml packages/api/
COPY packages/desktop/pyproject.toml packages/desktop/
COPY packages/embed/pyproject.toml packages/embed/
COPY packages/wincei/pyproject.toml packages/wincei/
COPY packages/wincei-hdr/pyproject.toml packages/wincei-hdr/
COPY packages/wincei-masks/pyproject.toml packages/wincei-masks/
COPY packages/wincei-api/pyproject.toml packages/wincei-api/

RUN uv sync --frozen --no-install-project --package pps-data 2>&1 | tail -10

RUN uv pip install --system \
    "accelerate>=0.34" \
    "peft>=0.13" \
    "diffusers>=0.31" \
    "transformers>=4.45" \
    "bitsandbytes>=0.44" \
    "wandb>=0.18" \
    "pyyaml>=6.0" \
    "lpips>=0.1.4" \
    "opencv-python-headless>=4.10" \
    "google-cloud-secret-manager>=2.20"

COPY packages/core packages/core
COPY packages/data packages/data
COPY training training

# Install only the two workspace members we need (pps-core, pps-data).
# `uv sync --frozen` without --package would walk the full workspace and
# fail because we deliberately didn't COPY source for agents/ai/api/etc.
RUN uv pip install --system -e packages/core -e packages/data 2>&1 | tail -5

ENV PPS_TRAINING_ROOT=/opt/pps

ENTRYPOINT ["python", "-u", "training/finetune_qwen_edit.py"]
CMD ["--config", "training/configs/fivek_lora.yaml", "--dry-run"]
